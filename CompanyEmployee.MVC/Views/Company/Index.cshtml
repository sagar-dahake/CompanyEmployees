@model List<CompanyEmployee.MVC.Models.Dtos.Company.CompanyDto>

@{
    ViewData["Title"] = "Companies";
}

<div class="page-header">
    Companies
</div>

<div class="card-enterprise">
    @if (Model == null || !Model.Any())
    {
        <div class="empty-state">
            <i class="bi bi-building" style="font-size:3rem; color:var(--muted);"></i>
            <h5 class="mt-3">No Companies Found</h5>
            <p>There are currently no companies in the system.</p>
        </div>
    }
    else
    {
        <table class="table table-enterprise align-middle">
            <thead>
                <tr>
                    <th style="width:70%">Company</th>
                    <th class="text-end">Action</th>
                </tr>
            </thead>

            <tbody>
                @foreach (var c in Model)
                {
                    <tr class="row-hover-enterprise">
                        <td>
                            <div class="d-flex align-items-center gap-3">
                                <div style="width:48px; height:48px; border-radius:10px; background:linear-gradient(135deg, var(--accent), #5146e8); display:grid; place-items:center;">
                                    <i class="bi bi-building" style="font-size:1.25rem;"></i>
                                </div>
                                <div>
                                    <div class="fw-semibold" style="font-size:1rem;">@c.Name</div>
                                    <small class="text-muted">
                                        <i class="bi bi-geo-alt me-1"></i>@c.FullAddress
                                    </small>
                                </div>
                            </div>
                        </td>

                        <td class="text-end">
                            <a asp-controller="Employee"
                               asp-action="Index"
                               asp-route-companyId="@c.Id"
                               asp-route-companyName="@c.Name"
                               class="btn btn-enterprise">
                                <i class="bi bi-people me-1"></i> View Employees
                            </a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    }
</div>