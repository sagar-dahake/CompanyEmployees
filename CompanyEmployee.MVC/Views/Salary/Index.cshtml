@model IEnumerable<Shared.DataTransferObjects.SalaryDto>

@{
    ViewData["Title"] = "Salary Records";
    var employeeId = ViewBag.EmployeeId as Guid? ?? Guid.Empty;
    var employeeName = ViewBag.EmployeeName as string ?? "Employee";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <div class="page-header mb-1">Salary Records</div>
        <div class="text-muted">
            <i class="bi bi-person me-1"></i>@employeeName
        </div>
    </div>
    <div class="d-flex gap-2">
        <a asp-controller="Employee" asp-action="Details" asp-route-id="@employeeId" class="btn btn-secondary">
            <i class="bi bi-arrow-left me-1"></i> Back to Employee
        </a>
        <a asp-action="Create" asp-route-employeeId="@employeeId" class="btn btn-enterprise">
            <i class="bi bi-plus-lg me-1"></i> Add Salary Record
        </a>
    </div>
</div>

<div class="card-enterprise">
    @if (!Model?.Any() ?? true)
    {
        <div class="empty-state">
            <i class="bi bi-cash-stack" style="font-size:3rem; color:var(--muted);"></i>
            <h5 class="mt-3">No Salary Records Found</h5>
            <p>No salary records have been added for this employee yet.</p>
            <a asp-action="Create" asp-route-employeeId="@employeeId" class="btn btn-enterprise mt-2">
                <i class="bi bi-plus-lg me-1"></i> Add First Salary Record
            </a>
        </div>
    }
    else
    {
        <table class="table table-enterprise">
            <thead>
                <tr>
                    <th>Effective From</th>
                    <th>Base Amount</th>
                    <th>Allowances</th>
                    <th>Total</th>
                    <th>Currency</th>
                    <th class="text-end">Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var s in Model)
                {
                    <tr class="row-hover-enterprise">
                        <td>
                            <i class="bi bi-calendar-event me-2"></i>
                            @s.EffectiveFrom.ToString("MMM dd, yyyy")
                        </td>
                        <td class="fw-semibold">@s.BaseAmount.ToString("N2")</td>
                        <td>@s.Allowances.ToString("N2")</td>
                        <td class="fw-semibold" style="color:var(--accent);">
                            @((s.BaseAmount + s.Allowances).ToString("N2"))
                        </td>
                        <td>
                            <span class="badge-enterprise">@s.Currency</span>
                        </td>
                        <td class="text-end">
                            <div class="d-flex justify-content-end gap-2">
                                <a asp-action="Edit" asp-route-employeeId="@employeeId" asp-route-id="@s.Id" class="btn btn-sm btn-secondary" title="Edit">
                                    <i class="bi bi-pencil"></i>
                                </a>

                                <form asp-action="Delete" asp-route-employeeId="@employeeId" asp-route-id="@s.Id" method="post" class="d-inline" onsubmit="return confirm('Delete this salary record?');">
                                    <button type="submit" class="btn btn-sm btn-danger" title="Delete">
                                        <i class="bi bi-trash"></i>
                                    </button>
                                </form>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    }
</div>