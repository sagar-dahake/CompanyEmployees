@model CompanyEmployee.MVC.Models.Dtos.Authentication.LoginDto

<style>
    :root {
        --hero-w: 1200px;
        --hero-h: 700px;
        --panel-radius: 22px;
        --accent: #7c5cff;
        --muted: rgba(255,255,255,0.65);
    }

    html, body {
        height: 100%;
        margin: 0;
    }

    /* full viewport hero */
    .auth-hero {
        width: 100vw;
        height: 100vh;
        display: flex;
        align-items: center;
        justify-content: center;
        background:
            radial-gradient(600px circle at 50% 30%, rgba(124,92,255,0.08), transparent 70%),
            radial-gradient(1200px circle at 10% 20%, rgba(124,92,255,0.04), transparent 80%),
            linear-gradient(180deg, rgba(8,10,18,1), rgba(18,20,36,1));
        overflow: hidden;
    }

    /* main rounded container (big card) */
    .hero-panel {
        width: min(var(--hero-w), 92vw);
        height: min(var(--hero-h), 86vh);
        border-radius: var(--panel-radius);
        position: relative;
        overflow: hidden;
        padding: 48px;
        display: flex;
        align-items: center;
        justify-content: center;
        box-shadow: 0 40px 110px rgba(3,6,15,0.75), inset 0 1px 0 rgba(255,255,255,0.02);
        background: linear-gradient(180deg, rgba(10,12,20,0.98), rgba(20,22,36,0.98));
    }

        /* decorative elongated blob */
        .hero-panel::before {
            content: "";
            position: absolute;
            left: -10%;
            top: 12%;
            width: 85%;
            height: 60%;
            border-radius: 100px;
            background: linear-gradient(90deg, rgba(255,255,255,0.02), rgba(255,255,255,0.01));
            transform: rotate(-16deg);
            filter: blur(10px);
            opacity: .11;
        }

        /* small decorative circles */
        .hero-panel .decor-dot {
            position: absolute;
            width: 140px;
            height: 140px;
            border-radius: 50%;
            right: 6%;
            bottom: 8%;
            background: radial-gradient(circle at 30% 30%, rgba(255,255,255,0.02), transparent 40%);
            opacity: .08;
            pointer-events: none;
        }

    /* globe decoration */
    .globe-wrap {
        position: relative;
        width: 120px;
        height: 120px;
        margin: 0 auto 1.5rem;
    }

    .globe-ring {
        position: absolute;
        inset: -12px;
        border-radius: 50%;
        border: 1px solid rgba(124,92,255,0.15);
        animation: spin-slow 20s linear infinite;
    }

    .globe-ring-inner {
        position: absolute;
        inset: -4px;
        border-radius: 50%;
        border: 1px solid rgba(124,92,255,0.08);
        animation: spin-slow 15s linear infinite reverse;
    }

    .globe-icon {
        width: 120px;
        height: 120px;
        border-radius: 50%;
        background: linear-gradient(135deg, rgba(124,92,255,0.2), rgba(81,70,232,0.15));
        display: grid;
        place-items: center;
        font-size: 3rem;
        color: rgba(255,255,255,0.85);
        position: relative;
        z-index: 2;
        box-shadow: 0 0 40px rgba(124,92,255,0.1);
    }

    @@keyframes spin-slow {
        from { transform: rotate(0deg); }
        to { transform: rotate(360deg); }
    }

    /* center column */
    .center-col {
        z-index: 3;
        width: 100%;
        max-width: 420px;
        display: flex;
        flex-direction: column;
        gap: 8px;
        align-items: center;
    }

    .brand-logo {
        color: #fff;
        font-size: 1.5rem;
        font-weight: 800;
        letter-spacing: -.5px;
        text-shadow: 0 8px 20px rgba(0,0,0,0.6);
        margin-bottom: .25rem;
    }

    .brand-subtitle {
        color: var(--muted);
        font-size: .8rem;
        letter-spacing: 2px;
        text-transform: uppercase;
        margin-bottom: 1rem;
    }

    .login-card {
        width: 100%;
        border-radius: 12px;
        padding: 24px;
        background: linear-gradient(180deg, rgba(12,14,24,0.88), rgba(22,24,36,0.88));
        box-shadow: 0 12px 30px rgba(2,6,23,0.6);
        border: 1px solid rgba(255,255,255,0.03);
    }

        .login-card .form-label {
            color: var(--muted);
            font-size: .75rem;
            display: block;
            margin-bottom: 6px;
        }

    .login-card .form-control {
        background: rgba(255,255,255,0.02);
        border: 1px solid rgba(255,255,255,0.04);
        color: #fff;
        border-radius: 8px;
        padding: .65rem .9rem;
        height: 42px;
        box-shadow: inset 0 1px 0 rgba(255,255,255,0.01);
    }

        .login-card .form-control::placeholder {
            color: rgba(255,255,255,0.32);
            text-transform: uppercase;
            font-size: .72rem;
        }

    .input-icon-group {
        position: relative;
    }

        .input-icon-group i {
            position: absolute;
            left: 12px;
            top: 50%;
            transform: translateY(-50%);
            color: rgba(255,255,255,0.3);
            font-size: .9rem;
            pointer-events: none;
        }

        .input-icon-group .form-control {
            padding-left: 2.25rem;
        }

    .btn-login {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        gap: .5rem;
        background: linear-gradient(90deg, var(--accent), #5b46e8);
        border: none;
        color: #fff;
        padding: .65rem 2rem;
        border-radius: 24px;
        font-weight: 700;
        font-size: .85rem;
        letter-spacing: 1px;
        text-transform: uppercase;
        width: 180px;
        margin: 14px auto 0;
        transition: all .2s ease;
        box-shadow: 0 4px 15px rgba(124,92,255,0.3);
    }

        .btn-login:hover {
            transform: translateY(-2px);
            box-shadow: 0 8px 25px rgba(124,92,255,0.4);
        }

    .forgot {
        color: rgba(255,255,255,0.55);
        font-size: .82rem;
        margin-top: 12px;
        text-decoration: underline;
        display: block;
        text-align: center;
        transition: color .2s;
    }

        .forgot:hover {
            color: rgba(255,255,255,0.8);
        }

    @@media (max-width: 720px) {
        .hero-panel {
            padding: 20px;
            height: 92vh;
            width: 94vw;
        }

        .globe-wrap {
            width: 90px;
            height: 90px;
        }

        .globe-icon {
            width: 90px;
            height: 90px;
            font-size: 2.2rem;
        }

        .brand-logo {
            font-size: 1.2rem;
        }

        .center-col {
            gap: 8px;
        }
    }
</style>

<div class="auth-hero" role="main" aria-live="polite">
    <div class="hero-panel" role="region" aria-label="Auth panel">
        <div class="decor-dot" aria-hidden="true"></div>

        <div class="center-col" role="form" aria-label="Sign in">
            <div class="globe-wrap" aria-hidden="true">
                <div class="globe-ring"></div>
                <div class="globe-ring-inner"></div>
                <div class="globe-icon">
                    <i class="bi bi-globe2"></i>
                </div>
            </div>

            <h1 class="brand-logo">CompanyEmployees</h1>
            <p class="brand-subtitle">HR Management Console</p>

            <div class="login-card" aria-label="Sign in card">
                <form asp-action="Login" method="post" novalidate>
                    <div class="mb-3">
                        <label asp-for="UserName" class="form-label">Email</label>
                        <div class="input-icon-group">
                            <i class="bi bi-person"></i>
                            <input asp-for="UserName" class="form-control" placeholder="Email address" />
                        </div>
                        <span asp-validation-for="UserName" class="text-danger small"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Password" class="form-label">Password</label>
                        <div class="input-icon-group">
                            <i class="bi bi-lock"></i>
                            <input asp-for="Password" type="password" class="form-control" placeholder="Password" />
                        </div>
                        <span asp-validation-for="Password" class="text-danger small"></span>
                    </div>

                    <div class="d-flex justify-content-center">
                        <button type="submit" class="btn-login">LOG IN</button>
                    </div>

                    <a asp-action="ForgotPassword" class="forgot">FORGOT YOUR PASSWORD?</a>
                </form>
            </div>
        </div>
    </div>
</div>