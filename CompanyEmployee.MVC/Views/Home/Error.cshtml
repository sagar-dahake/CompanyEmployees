@{
    ViewData["Title"] = "Error";
}

<div class="d-flex flex-column align-items-center justify-content-center" style="min-height:60vh;">
    <div class="text-center">
        <i class="bi bi-exclamation-triangle-fill" style="font-size:4rem;color:var(--accent,#7c5cff);"></i>
        <h2 class="mt-3">Something went wrong</h2>
        <p class="text-muted mt-2">An unexpected error occurred. The error has been logged and our team will look into it.</p>
        <a href="@Url.Action("Login", "Auth")" class="btn btn-primary mt-3">
            <i class="bi bi-arrow-left"></i> Back to Login
        </a>
    </div>
</div>
