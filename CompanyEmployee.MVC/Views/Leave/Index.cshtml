@model IEnumerable<Shared.DataTransferObjects.LeaveRecordDto>

@{
    ViewData["Title"] = "Leave Records";
    var employeeId = ViewBag.EmployeeId as Guid? ?? Guid.Empty;
    var employeeName = ViewBag.EmployeeName as string ?? "Employee";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <div class="page-header mb-1">Leave Records</div>
        <div class="text-muted">
            <i class="bi bi-person me-1"></i>@employeeName
        </div>
    </div>
    <div class="d-flex gap-2">
        <a asp-controller="Employee" asp-action="Details" asp-route-id="@employeeId" class="btn btn-secondary">
            <i class="bi bi-arrow-left me-1"></i> Back to Employee
        </a>
        <a asp-action="Create" asp-route-employeeId="@employeeId" class="btn btn-enterprise">
            <i class="bi bi-calendar-plus me-1"></i> Request Leave
        </a>
    </div>
</div>

<div class="card-enterprise">
    @if (!Model?.Any() ?? true)
    {
        <div class="empty-state">
            <i class="bi bi-calendar-check" style="font-size:3rem; color:var(--muted);"></i>
            <h5 class="mt-3">No Leave Records Found</h5>
            <p>No leave applications have been created for this employee yet.</p>
            <a asp-action="Create" asp-route-employeeId="@employeeId" class="btn btn-enterprise mt-2">
                <i class="bi bi-calendar-plus me-1"></i> Request First Leave
            </a>
        </div>
    }
    else
    {
        <table class="table table-enterprise">
            <thead>
                <tr>
                    <th>Type</th>
                    <th>Period</th>
                    <th>Days</th>
                    <th>Status</th>
                    <th>Reason</th>
                    <th class="text-end">Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var l in Model)
                {
                    var statusClass = l.Status switch
                    {
                        1 => "success", // Approved
                        2 => "danger",  // Rejected
                        3 => "secondary", // Cancelled
                        _ => "warning"  // Pending
                    };

                    <tr class="row-hover-enterprise">
                        <td>
                            <span class="badge-enterprise">@l.TypeName</span>
                        </td>
                        <td>
                            <i class="bi bi-calendar-range me-2"></i>
                            @l.StartDate.ToString("MMM dd") - @l.EndDate.ToString("MMM dd, yyyy")
                        </td>
                        <td class="fw-semibold">@l.Days days</td>
                        <td>
                            <span class="badge bg-@statusClass">@l.StatusName</span>
                        </td>
                        <td>
                            <small class="text-muted">@(l.Reason ?? "-")</small>
                        </td>
                        <td class="text-end">
                            <div class="d-flex justify-content-end gap-2">
                                <a asp-action="Get" asp-route-employeeId="@employeeId" asp-route-id="@l.Id" class="btn btn-sm btn-primary" title="View">
                                    <i class="bi bi-eye"></i>
                                </a>

                                @if (l.Status == 0) // Pending
                                {
                                    <a asp-action="Update" asp-route-employeeId="@employeeId" asp-route-id="@l.Id" class="btn btn-sm btn-secondary" title="Edit">
                                        <i class="bi bi-pencil"></i>
                                    </a>
                                }

                                <form asp-action="Delete" asp-route-employeeId="@employeeId" asp-route-id="@l.Id" method="post" class="d-inline" onsubmit="return confirm('Delete this leave record?');">
                                    <button type="submit" class="btn btn-sm btn-danger" title="Delete">
                                        <i class="bi bi-trash"></i>
                                    </button>
                                </form>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    }
</div>